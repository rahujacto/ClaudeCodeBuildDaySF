# ── Supabase ─────────────────────────────────────────────────────────────
# Settings → API in your Supabase project dashboard.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never exposed to the client. Used by server routes/adapters.
SUPABASE_SERVICE_ROLE_KEY=

# ── App-level secret encryption ──────────────────────────────────────────
# 32-byte key, base64-encoded. Used to AES-256-GCM encrypt connection tokens
# before they touch the DB. Decryption happens ONLY in server code.
# Generate: openssl rand -base64 32
ENCRYPTION_KEY=

# ── Anthropic (agentic chat) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── GA4 data OAuth (Gate 8 / expand-if-time) ─────────────────────────────
# Separate from Google *login* OAuth (which is configured in the Supabase
# dashboard). This is the analytics.readonly data grant from the Capgown GCP.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Public base URL (used to build OAuth redirect URIs). Locally: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Team invite emails (optional, via Resend) ────────────────────────────
# If unset, invites still work as an allowlist (no email is sent).
# RESEND_FROM must be on a domain verified in your Resend account.
RESEND_API_KEY=
RESEND_FROM=Pulse <invites@yourdomain.com>
